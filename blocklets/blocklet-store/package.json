  "nyc": {
    "all": true,
    "report-dir": "coverage",
    "include": [
      "src/**/*.js",
      "api/**/*.js"
    ],
    "exclude": [
      "api/hooks/*.js",
      "**/*.spec.js",
      "**/*.test.js"
    ]
