  "scripts": {
    "dev": "blocklet dev --start-all-components",
    "dev:install": "blocklet dev install --app-id=zNKn87cLuqrNHDaoiQY1Ki7L3PWZscQiN7Nq --mount-point=/",
    "dev:start": "blocklet dev start --app-id=zNKn87cLuqrNHDaoiQY1Ki7L3PWZscQiN7Nq --mount-point=/",
    "dev:child": "blocklet dev --app-id=zNKn87cLuqrNHDaoiQY1Ki7L3PWZscQiN7Nq --mount-point=/",
    "lint": "eslint src api --ext=js,jsx,ts,tsx,mjs",
    "lint:fix": "npm run lint -- --fix",
    "clean": "rm -rf .blocklet .cypress coverage .env.e2e .env.development",
    "start:client-ux-blocklet-list": "NODE_ENV=development cd ../../packages/list && npm run watch",
    "start": "nodemon -w api api/dev.mjs",
    "e2e-start": "npm-run-all --parallel e2e-start:*",
    "e2e-start:server": "NODE_ENV=e2e nyc --silent node scripts/server.js",
    "build:client": "cross-env NODE_OPTIONS=--max-old-space-size=6144 vite build",
    "build:analyze": "ANALYZE_BUILD=true vite build",
    "bundle": "npm run clean && npm run bundle:client && npm run bundle:server",
    "bundle:client": "npm run build:client",
    "bundle:server": "cross-env NODE_ENV=production blocklet bundle --compact --external @aigne/sqlite --create-release --monorepo",
    "deploy": "npm run bundle && blocklet deploy .blocklet/bundle",
    "coverage": "vitest run --coverage",
    "coverage:prepare": "npm run clean && node scripts/prepare.js",
    "coverage:start": "NODE_ENV=e2e dotenv-flow -- scripts/start.sh",
    "coverage:e2e": "start-server-and-test coverage:start 8090 cypress-ci",
    "coverage:merge": "./scripts/merge-coverage.sh",
    "cypress-e2e": "cypress open",
    "cypress-install": "cypress install",
    "cypress-ci": "cypress run --headed --browser chrome --record false && nyc report --reporter=text"
  },
  "browserslist": {
    "production": [
      ">0.1%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,mjs,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{css,less,scss,json,graphql}": [
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "lint-staged"
    }
  },
  "devDependencies": {
    "@abtnode/constant": "^1.17.12",
