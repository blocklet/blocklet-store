    "nodemon": "^2.0.19",
    "npm-run-all": "^4.1.5",
    "nyc": "^15.1.0",
    "prettier": "^3.3.2",
    "rollup-plugin-visualizer": "^5.14.0",
    "start-server-and-test": "^3.0.2",
