  "scripts": {
    "prepare:workspace": "pnpm --filter @blocklet/util build && pnpm --filter @blocklet/list build",
    "prelint": "npm run prepare:workspace",
    "lint": "pnpm -r --if-present lint",
    "lint:fix": "pnpm -r --if-present lint:fix",
    "build": "pnpm -r --if-present clean && pnpm -r --if-present build",
    "clean": "pnpm -r --if-present clean",
    "pretest": "npm run prepare:workspace",
    "test": "CI=1 pnpm -r --if-present test",
    "coverage:prepare": "pnpm -r --if-present coverage:prepare",
    "coverage": "CI=1 pnpm -r --if-present coverage",
    "coverage:merge": "pnpm -r --if-present coverage:merge",
    "update:deps": "taze -f -r -n '/arcblock|ocap|abtnode|blocklet|did-connect|did-comment|nedb/' -w && pnpm install && pnpm dedupe",
    "verify": "npm run build && npm run lint && pnpm -r --if-present bundle",
    "storybook": "storybook dev -p 6006",
    "test-storybook": "vitest --config=vitest.storybook.ts --coverage",
    "build-storybook": "storybook build",
    "prepare": "husky install",
    "precommit": "npm run lint && npm run test",
    "bump-version": "make bump-version",
    "deploy:lambda": "zx --quiet scripts/deploy-lambda.mjs"
  }
